# VoyageAI backend — environment variables. Copy to backend/.env for local dev.

# Required
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Optional — defaults are fine for local dev.
# Data dir for SQLite + Chroma (Railway: set this to /data).
VOYAGEAI_DATA_DIR=./data

# Comma-separated allowed origins for CORS.
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Models
EMBED_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
RAG_TOP_K=5
